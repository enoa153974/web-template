<div class="feature-media media">

    <div class="media__image">
        <img src="{{image}}" alt="{{alt}}">
    </div>

    <div class="media__body">

        {{#if label}}
        <p class="feature-media__label">
            {{label}}
        </p>
        {{/if}}

        {{#if title}}
        <h3 class="feature-media__title">
            {{title}}
        </h3>
        {{/if}}

        {{#if text}}
        <p class="feature-media__text">
            {{text}}
        </p>
        {{/if}}

        {{#if button}}
        <div class="feature-media__cta">
            <a href="{{buttonLink}}" class="button button--primary">
                {{button}}
            </a>
        </div>
        {{/if}}

    </div>

</div>
<section class="l-section l-section--hero">
    <div class="c-hero c-hero--center">

        <div class="c-hero__bg">
            <img src="/images/hero_sample.png" alt="" />
        </div>

        <div class="c-hero__overlay"></div>

        <div class="l-container">
            <div class="c-hero__content">
                <h1 class="c-hero__title">
                    未来をつくるテクノロジー
                </h1>
                <p class="c-hero__lead">
                    私たちはデジタルの力で企業の成長を支援します。
                </p>

                <div class="c-hero__actions">
                    {{> components/cta/cta-actions
                    primaryText="無料相談"
                    primaryUrl="/contact"
                    secondaryText="資料請求"
                    secondaryUrl="/download"
                    }}

                </div>
            </div>
        </div>

    </div>
</section>